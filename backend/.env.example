# --- App ---
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_ORIGIN=http://localhost:5173

# --- Base de datos (MySQL en cPanel) ---
# Formato: mysql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL="mysql://wms_user:CHANGE_ME@localhost:3306/wms_chimuelo"

# --- WordPress / WooCommerce ---
WP_BASE_URL=https://dev.chimuelo.cl
WP_JWT_SECRET=CHANGE_ME_must_match_wp_config_JWT_AUTH_SECRET_KEY

# WooCommerce REST API (Settings > Advanced > REST API en WP)
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret compartido del webhook de WooCommerce
WC_WEBHOOK_SECRET=CHANGE_ME

# --- Convenciones de meta fields (deben coincidir con el plugin WP) ---
META_PRODUCT_WAREHOUSE=_wms_bodega
META_ORDER_ROUTE=_wdg_route
META_ORDER_STOP_POSITION=_wdg_stop_position
