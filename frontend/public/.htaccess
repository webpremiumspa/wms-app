# SPA rewrite para WMS Chimuelo.
# La app Node (Passenger) ya intercepta /api/* automáticamente porque está
# configurada con Application URL = wms.chimuelo.cl/api. Apache no toca esas
# URLs. Aquí solo manejamos el resto: archivos estáticos y fallback al SPA.

RewriteEngine On
RewriteBase /

# Si el archivo o carpeta existe, lo sirve tal cual (assets, index.html, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Cualquier otra cosa (rutas de React Router) → index.html
RewriteRule ^ /index.html [L]

# Cache largo para assets versionados de Vite (los nombres incluyen hash).
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot|png|jpg|jpeg|gif|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # index.html y manifest no deben cachearse (para que la PWA refresque).
  <FilesMatch "^(index\.html|manifest\.webmanifest|sw\.js|registerSW\.js|workbox-.*\.js)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
