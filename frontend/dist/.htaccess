# SPA + reverse proxy para WMS Chimuelo.
# La app Node (Passenger) está mapeada a wms.chimuelo.cl/api. Esta .htaccess
# se encarga de no reescribir /api/* y de mandar el resto al SPA.

RewriteEngine On
RewriteBase /

# Bloquear acceso público a carpetas fuente (el repo está clonado en el doc root).
RewriteRule ^backend(/.*)?$  - [F,L]
RewriteRule ^frontend(/.*)?$ - [F,L]
RewriteRule ^docs(/.*)?$     - [F,L]
RewriteRule ^\.cpanel\.yml$  - [F,L]
RewriteRule ^\.git(/.*)?$    - [F,L]

# /api/* lo maneja Passenger (app Node). NO reescribir aquí — el L termina
# el procesamiento de rewrites y deja que LiteSpeed/Passenger entregue
# el request a la app Node correctamente.
RewriteRule ^api(/.*)?$ - [L]

# Si el archivo/carpeta existe físicamente, servir tal cual.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Cualquier otra ruta (React Router) → index.html.
RewriteRule ^ /index.html [L]

# Cache largo para assets versionados de Vite (incluyen hash).
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot|png|jpg|jpeg|gif|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # index.html y manifest no deben cachearse (para que la PWA refresque).
  <FilesMatch "^(index\.html|manifest\.webmanifest|sw\.js|registerSW\.js|workbox-.*\.js)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

Options -Indexes
